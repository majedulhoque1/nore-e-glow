# Supabase (publishable values — safe for the client bundle, but keep real
# .env files out of git so secrets are never committed by accident).
# NEVER put a service_role key in any VITE_ variable: it would ship to browsers.
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-publishable-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Optional: WhatsApp number used for "Order via WhatsApp" links (digits only)
VITE_WHATSAPP_NUMBER="8801XXXXXXXXX"
